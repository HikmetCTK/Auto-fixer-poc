# ============================================
# AI Bug Detective — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- LLM Providers ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
CEREBRAS_API_KEY=your-cerebras-key
OPENROUTER_API_KEY=your-openrouter-key

# --- AWS Bedrock ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION_NAME=us-east-1

# --- Default Model ---
DEFAULT_MODEL=cerebras/gpt-oss-120b
FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://app:changeme@localhost:5432/bugdetective
POSTGRES_PASSWORD=changeme

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=bug-detective-queue

# --- Langfuse (Phase 2) ---
# LANGFUSE_PUBLIC_KEY=your-public-key
# LANGFUSE_SECRET_KEY=your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
USE_NATIVE_TOOL_CALLING=false
